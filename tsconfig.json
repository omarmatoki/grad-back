{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",

    "incremental": true,
    "skipLibCheck": true,

    // Strict Mode مع بعض التخفيفات المناسبة لـ NestJS
    "strict": true,
    "strictPropertyInitialization": false,     // يحل أخطاء "has no initializer"
    "useUnknownInCatchVariables": false,       // يحل أخطاء error is of type 'unknown'

    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,

    // لإسكات تحذير baseUrl القديم
    "ignoreDeprecations": "5.0",

    // Path aliases (مهم جداً)
    "paths": {
      "@modules/*": ["./src/modules/*"],
      "@common/*": ["./src/common/*"],
      "@config/*": ["./src/config/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*.spec.ts"]
}